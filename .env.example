# ── Supabase ──────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# OAuth callback path (default: /auth/callback)
VITE_SUPABASE_AUTH_REDIRECT_PATH="/auth/callback"

# Google OAuth via Supabase Auth (set to "true" after configuring in Supabase dashboard)
VITE_SUPABASE_GOOGLE_ENABLED="false"

# ── Gemini AI ─────────────────────────────────────────────
# GEMINI_API_KEY is set as a Supabase secret for edge functions (not VITE_).
# For local dev, you can enable direct Gemini calls with these two vars:
VITE_GEMINI_API_KEY=""
VITE_ENABLE_DIRECT_GEMINI="false"

# ── Dev / optional ────────────────────────────────────────
# APP_URL: The URL where this app is hosted (dev default).
APP_URL="http://localhost:3000"
