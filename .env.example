# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# YOUTUBE_API_KEY: Optional for local development.
YOUTUBE_API_KEY="MY_YOUTUBE_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:5173"

# Supabase client configuration
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_AUTH_REDIRECT_PATH="/auth/callback"
# Optional explicit production override for OAuth callbacks.
VITE_SUPABASE_AUTH_REDIRECT_URL="https://jesus-frameflow.web.app/auth/callback"

# Dev-only direct Gemini fallback for local testing.
VITE_GEMINI_API_KEY=""

# Google OAuth via Supabase Auth (set to "true" after configuring in Supabase dashboard)
VITE_SUPABASE_GOOGLE_ENABLED="false"
